# LLM Provider — "sarvam" or "lmstudio"
LLM_PROVIDER=sarvam

# Sarvam AI
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_BASE_URL=https://api.sarvam.ai/v1
SARVAM_MODEL=sarvam-105b

# LM Studio (local fallback)
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=local-model

# n8n
N8N_ENCRYPTION_KEY=your_random_32char_string_here
N8N_URL=http://n8n:5678
N8N_API_KEY=changeme_after_first_login
N8N_RUNNERS_AUTH_TOKEN=your_random_runner_auth_token_here

# Google Sheets logging for n8n Day 4 workflow
GOOGLE_SHEET_ID=your_inquiry_execution_log_sheet_id
GOOGLE_SHEET_NAME=Sheet1

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# FastAPI
SECRET_KEY=your_random_secret_key_here
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
