# LLM Provider — "sarvam" or "lmstudio"
LLM_PROVIDER=sarvam

# Sarvam AI
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_BASE_URL=https://api.sarvam.ai/v1
SARVAM_MODEL=sarvam-105b

# LM Studio (local fallback)
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=local-model

# n8n
N8N_ENCRYPTION_KEY=your_random_32char_string_here
N8N_URL=http://n8n:5678
N8N_API_KEY=changeme_after_first_login
N8N_RUNNERS_AUTH_TOKEN=your_random_runner_auth_token_here

# Google Sheets logging for n8n Day 4 workflow. Use the spreadsheet ID, not the full URL.
GOOGLE_SHEET_ID=your_inquiry_execution_log_sheet_id
GOOGLE_SHEET_NAME=Sheet1

# Google Drive KB file IDs used by the Researcher path in n8n.
# Set a default OR intent-specific IDs (intent-specific takes priority).
GOOGLE_DRIVE_KB_DEFAULT_FILE_ID=
GOOGLE_DRIVE_KB_SALES_FILE_ID=
GOOGLE_DRIVE_KB_SUPPORT_FILE_ID=
GOOGLE_DRIVE_KB_COMPLAINT_FILE_ID=
GOOGLE_DRIVE_KB_GENERAL_FILE_ID=
GOOGLE_DRIVE_KB_ORDER_FILE_ID=
GOOGLE_DRIVE_KB_FILE_ID=

# Gmail reply handling: "auto" sends replies for the Layer 3 demo; "review" creates drafts for human approval.
GMAIL_SEND_MODE=auto

# Telegram (optional second channel)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=optional_webhook_secret

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# FastAPI
SECRET_KEY=your_random_secret_key_here
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
